## App
APP_NAME=JARVISv7
JARVIS_LANGUAGE=english

## Local Model runtime intent
USE_LOCAL_MODEL=true
LLM_MODEL_POLICY=auto
LLM_MODEL_ID=

## Use Local Ollama intent
USE_OLLAMA=false
OLLAMA_MODEL=

## Optional search/services
# SearXNG Search requires Docker
USE_SEARXNG=false
SEARXNG_PORT=8888
# Duck-Duck-Go Search has usage limits
USE_DDGS=true
# Tavily Search requires an API key
USE_TAVILY=false
TAVILY_API_KEY=
# Redis Cache requires Docker
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

## Optional wake service (not typically needed)
PICOVOICE_ACCESS_KEY=
