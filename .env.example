# App/runtime
## Core app runtime identity, logging, and model fetch behavior.
APP_NAME=JARVISv7

# Test gates
## Toggle for enabling live tests that may involve external API calls or long-running processes.
JARVISV7_LIVE_TESTS=false

# Paths
## Filesystem roots for config, data, and model assets and runtime data.
CONFIG_PATH=config/
DATA_PATH=data/
MODEL_PATH=models/

# Local LLM
## Download local model usage toggle, fetch behavior, and model selection.
USE_LOCAL_MODEL=false
LOCAL_MODEL_FETCH=false
LLAMA_CPP_MODEL_PATH=models/llm

# Ollama
## Local Ollama application endpoint and default model selection.
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini
OLLAMA_NUM_CTX=8192

# Voice models
## Voice model paths for text-to-speech and speech-to-text functionality.
TTS_MODELS=models/tts
STT_MODELS=models/stt
WAKE_MODEL=models/wake

# Optional wake/QNN operator settings
## Wake word detection model path and access key (porcupine).
PVPORCUPINE_MODEL_PATH=
PICOVOICE_ACCESS_KEY=

# AI Accelerator Tools
## Qualcomm AI Runtime SDK path for QNN operator support in local LLMs.
QAIRT_SDK_PATH=

# Redis configuration
## Redis server connection settings.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=2.0

# Search escalation
## Priority search engine
USE_SEARXNG=true
SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_PORT=8080
## Secondary search engine
USE_DDGS=true
## Tertiary search engine (requires API key)
USE_TAVILY=false
TAVILY_API_KEY=
