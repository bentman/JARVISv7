# [app/runtime]
# Core app runtime identity, logging, and model fetch behavior.
APP_NAME=JARVISv7

# [paths]
# Filesystem roots for config, data, and model assets and runtime data.
CONFIG_PATH=config/
DATA_PATH=data/
MODEL_PATH=models/

# [local llm model]
# Download local model usage toggle, fetch behavior, and model selection.
USE_LOCAL_MODEL=false
LOCAL_MODEL_FETCH=never
LLAMA_CPP_MODEL_PATH=models/llm

# [ollama model]
# Local Ollama application endpoint and default model selection.
JARVISV7_OLLAMA_URL=http://127.0.0.1:11434
USE_OLLAMA=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi4-mini
# OLLAMA_NUM_CTX host guidance: Windows ARM64=4096, Windows x64=8192.
OLLAMA_NUM_CTX=8192

# [voice models]
# Voice model paths for text-to-speech and speech-to-text functionality.
TTS_MODELS=models/tts
STT_MODELS=models/stt
WAKE_MODEL=models/wake

# [wake model alternates]
# Wake word detection model path and access key (porcupine).
# PVPORCUPINE_MODEL_PATH=models/wake/Jarvis_en_windows_v4_0_0.ppn
# PICOVOICE_ACCESS_KEY=<secret key here>
