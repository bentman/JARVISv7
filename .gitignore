# JARVISv7 .gitignore

# ------------------------------------------------------------
# Secrets and local environment
# ------------------------------------------------------------
# root env files
/.env
/.env.local
/.env.*

# tracked example
!/.env.example

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
# bytecode / interpreter
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# packaging / build outputs
build/
dist/
downloads/
develop-eggs/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# virtual environments
.venv/
venv/
ENV/
env/
/backend/.venv/

# tooling caches
.mypy_cache/
.ruff_cache/


# ------------------------------------------------------------
# Testing and coverage artifacts
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage/


# ------------------------------------------------------------
# Frontend / Node
# ------------------------------------------------------------
# dependency dirs
node_modules/

# package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# build/cache outputs (repo-root anchored)
/frontend/dist/
/frontend/.vite/
dist-ssr/

# local overrides
*.local


# ------------------------------------------------------------
# Desktop / Tauri
# ------------------------------------------------------------
/desktop/node_modules/
/desktop/dist/
/desktop/src-tauri/target/
/desktop/src-tauri/gen/


# ------------------------------------------------------------
# Docker overrides (local only)
# ------------------------------------------------------------
/docker-compose.override.yml


# ------------------------------------------------------------
# IDE / editor / OS
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ------------------------------------------------------------
# Runtime data artifacts (local-first architecture)
# ------------------------------------------------------------
# base gate: block everything under /data/
/data/*

# re-include tree roots documented in repo_tree.md
# (directories must be re-included before their contents)
!/data/agents/
!/data/memory/
!/data/sessions/
!/data/temp/
!/data/turns/

# data/agents (agent ledger; I.2)
/data/agents/*
!/data/agents/.gitkeep

# data/memory (working, episodic, semantic)
/data/memory/*
!/data/memory/.gitkeep
!/data/memory/episodic/
/data/memory/episodic/*
!/data/memory/episodic/.gitkeep
!/data/memory/semantic/
/data/memory/semantic/*
!/data/memory/semantic/.gitkeep
!/data/memory/working/
/data/memory/working/*
!/data/memory/working/.gitkeep

# data/sessions
/data/sessions/*
!/data/sessions/.gitkeep

# data/temp
/data/temp/*
!/data/temp/.gitkeep

# data/turns
/data/turns/*
!/data/turns/.gitkeep

# generic runtime artifacts (fallback)
/data/**/*.db
/data/**/*.db-journal
/data/**/*.db-wal
/data/**/*.sqlite
/data/**/*.sqlite3
/data/**/*.log
/data/**/embeddings/**


# ------------------------------------------------------------
# Top-level cache/ (Redis local persistence, temp outputs)
# ------------------------------------------------------------
/cache/*
!/cache/.gitkeep
/cache/redis/*
!/cache/redis/
!/cache/redis/.gitkeep
/cache/temp/*
!/cache/temp/
!/cache/temp/.gitkeep


# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
# global logs
*.log

# root logs dir only
/logs/

# ------------------------------------------------------------
# Reports (validation, diagnostics, benchmarks)
# ------------------------------------------------------------
/reports/*.txt
/reports/*.err
/reports/*.json
/reports/benchmarks/*
!/reports/benchmarks/.gitkeep
/reports/diagnostics/*
!/reports/diagnostics/.gitkeep
/reports/tests/*
!/reports/tests/.gitkeep
/reports/validation/*
!/reports/validation/.gitkeep
!/reports/.gitkeep


# ------------------------------------------------------------
# Model artifacts (per-folder allowlist; prevent large binary commits
# but permit `.gitkeep` placeholders)
# ------------------------------------------------------------
/models/llm/*
!/models/llm/.gitkeep
/models/stt/*
!/models/stt/.gitkeep
/models/tts/*
!/models/tts/.gitkeep
/models/wake/*
!/models/wake/.gitkeep

# Model binary extensions (anywhere): kept out of source.
# Note: `.onnx` is NOT globally banned — ONNX models live under /models/**
# and are gated by the per-folder rules above. Other locations (tests/fixtures)
# should hold small ONNX files only when intentional.
**/*.gguf
**/*.bin
**/*.safetensors
**/*.pt
**/*.pth
**/*.ckpt
**/*.ppn
