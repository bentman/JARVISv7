{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JARVISv7",
  "version": "0.0.1",
  "identifier": "com.jarvisv7.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "JARVISv7",
        "width": 1180,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8765; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": "all"
  }
}
